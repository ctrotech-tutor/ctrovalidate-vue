{
  "name": "ctrovalidate-vue",
  "version": "1.0.0",
  "description": "Vue 3 adapter for Ctrovalidate - The lightweight, declarative validation library.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier . --check"
  },
  "homepage": "https://ctrovalidate.vercel.app/api/vue",
  "keywords": [
    "ctrovalidate",
    "validation",
    "form-validation",
    "vue",
    "vue3"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctrotech-tutor/ctrovalidate-vue.git"
  },
  "bugs": {
    "url": "https://github.com/ctrotech-tutor/ctrovalidate-vue/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "ctrovalidate-core": "^1.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "ctrovalidate-core": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.2.0",
    "prettier": "^3.1.1",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.0"
  }
}
